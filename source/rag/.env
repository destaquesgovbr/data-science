# Environment Variables - Issue #5 RAG System
# Auto-generated configuration

# ===========================
# Database (PostgreSQL)
# ===========================
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=news_db
POSTGRES_USER=rag_user
POSTGRES_PASSWORD=rag_password_2024

# Connection pool settings
POSTGRES_POOL_MIN=2
POSTGRES_POOL_MAX=10

# ===========================
# LLM Providers
# ===========================

# AWS Bedrock (configured via AWS CLI)
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-20250514-v1:0

# ===========================
# Re-ranking
# ===========================

# Use local cross-encoder (no API key needed)
USE_LOCAL_RERANKER=true
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-12-v2

# ===========================
# Embeddings (BGE-M3 from Issue #1)
# ===========================
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIMENSION=1024
EMBEDDING_DEVICE=cpu  # Running on CPU
EMBEDDING_BATCH_SIZE=32

# ===========================
# Retrieval Configuration
# ===========================

# Vector search (pgvector)
VECTOR_SEARCH_TOP_K=50
IVFFLAT_PROBES=10

# Full-text search
FULLTEXT_SEARCH_TOP_K=50

# Hybrid fusion
HYBRID_RRF_K=60

# Re-ranking
RERANK_TOP_K=10
FINAL_TOP_K=5

# ===========================
# Generation Configuration
# ===========================

# LLM settings
LLM_TEMPERATURE=0
LLM_MAX_TOKENS=1000
LLM_TIMEOUT=30

# Context assembly
MAX_CONTEXT_LENGTH=8000

# ===========================
# API Configuration
# ===========================

# REST API
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# Rate limiting
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_HOUR=1000

# ===========================
# MCP Server Configuration
# ===========================
MCP_SERVER_PORT=3000
MCP_SERVER_NAME=rag-news-gov

# ===========================
# Caching
# ===========================

# Enable caching (no Redis for now)
CACHE_EMBEDDINGS=true
CACHE_RESPONSES=false

# ===========================
# Monitoring
# ===========================

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=text

# ===========================
# Development
# ===========================
DEBUG=false
ENVIRONMENT=development
