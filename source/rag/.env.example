# Environment Variables - Issue #5 RAG System
# Copy to .env and fill with your values

# ===========================
# Database (PostgreSQL)
# ===========================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=news_db
POSTGRES_USER=your_user
POSTGRES_PASSWORD=your_password

# Connection pool settings
POSTGRES_POOL_MIN=2
POSTGRES_POOL_MAX=10

# ===========================
# LLM Providers
# ===========================

# Option 1: Anthropic (Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Option 2: AWS Bedrock (Claude via Bedrock)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-20250514-v1:0

# Option 3: OpenAI (GPT)
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o

# ===========================
# Re-ranking
# ===========================

# Cohere Rerank API (optional)
COHERE_API_KEY=your_cohere_api_key

# Or use local cross-encoder (no key needed)
USE_LOCAL_RERANKER=true
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-12-v2

# ===========================
# Embeddings (BGE-M3 from Issue #1)
# ===========================
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIMENSION=1024
EMBEDDING_DEVICE=cuda  # or 'cpu'
EMBEDDING_BATCH_SIZE=32

# ===========================
# Retrieval Configuration
# ===========================

# Vector search (pgvector)
VECTOR_SEARCH_TOP_K=50
IVFFLAT_PROBES=10  # Balance precision/speed

# Full-text search
FULLTEXT_SEARCH_TOP_K=50

# Hybrid fusion
HYBRID_RRF_K=60  # Reciprocal Rank Fusion parameter

# Re-ranking
RERANK_TOP_K=10
FINAL_TOP_K=5

# ===========================
# Generation Configuration
# ===========================

# LLM settings
LLM_TEMPERATURE=0  # Deterministic for factual QA
LLM_MAX_TOKENS=1000
LLM_TIMEOUT=30  # seconds

# Context assembly
MAX_CONTEXT_LENGTH=8000  # tokens (leave room for query + instructions)

# ===========================
# API Configuration
# ===========================

# REST API
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# Authentication
API_KEY_HEADER=X-API-Key
API_KEYS=key1,key2,key3  # Comma-separated

# Rate limiting
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_HOUR=1000

# ===========================
# MCP Server Configuration
# ===========================
MCP_SERVER_PORT=3000
MCP_SERVER_NAME=rag-news-gov

# ===========================
# Caching
# ===========================

# Redis (optional)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_TTL=86400  # 24 hours

# Enable caching
CACHE_EMBEDDINGS=true
CACHE_RESPONSES=true

# ===========================
# Monitoring
# ===========================

# Prometheus
METRICS_PORT=9090

# Logging
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR
LOG_FORMAT=json  # json or text

# ===========================
# Development
# ===========================
DEBUG=false
ENVIRONMENT=development  # development, staging, production
